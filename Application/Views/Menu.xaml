<UserControl x:Class="ToolKitV.Views.Menu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ToolKitV.Views"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Section label -->
        <TextBlock Grid.Row="0"
                   Text="TOOLS"
                   Foreground="#40FFFFFF"
                   FontFamily="Fonts/#TT Norms"
                   FontSize="10"
                   FontWeight="Bold"
                   Margin="16 20 0 12"/>

        <!-- Nav items -->
        <StackPanel Grid.Row="1" Margin="10 0">

            <!-- Texture Optimizer — ACTIVE -->
            <Border Height="46" CornerRadius="8" Margin="0 2" Cursor="Hand">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#30C0132A" Offset="0"/>
                        <GradientStop Color="#15C0132A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <!-- Left accent stripe -->
                <Grid>
                    <Rectangle Width="3" HorizontalAlignment="Left" RadiusX="2" RadiusY="2">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FF5555" Offset="0"/>
                                <GradientStop Color="#C0132A" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14 0 0 0">
                        <TextBlock Text="🖼" FontSize="14" VerticalAlignment="Center" Margin="0 0 10 0"/>
                        <TextBlock Text="Texture Optimizer"
                                   Foreground="#FFFFFFFF"
                                   FontFamily="Fonts/#TT Norms"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Vehicles — Coming Soon -->
            <Border Height="46" CornerRadius="8" Margin="0 2" Opacity="0.35" Cursor="Arrow">
                <Border.Background><SolidColorBrush Color="#10FFFFFF"/></Border.Background>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="17 0 0 0">
                    <TextBlock Text="🚗" FontSize="14" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <StackPanel>
                        <TextBlock Text="Vehicles"
                                   Foreground="#80FFFFFF"
                                   FontFamily="Fonts/#TT Norms"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Coming soon"
                                   Foreground="#40FFFFFF"
                                   FontFamily="Fonts/#TT Norms"
                                   FontSize="9"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Clothes — Coming Soon -->
            <Border Height="46" CornerRadius="8" Margin="0 2" Opacity="0.35" Cursor="Arrow">
                <Border.Background><SolidColorBrush Color="#10FFFFFF"/></Border.Background>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="17 0 0 0">
                    <TextBlock Text="👕" FontSize="14" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <StackPanel>
                        <TextBlock Text="Clothes"
                                   Foreground="#80FFFFFF"
                                   FontFamily="Fonts/#TT Norms"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Coming soon"
                                   Foreground="#40FFFFFF"
                                   FontFamily="Fonts/#TT Norms"
                                   FontSize="9"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Margin="16 0 0 16">
            <TextBlock Text="TGTheAnimator"
                       Foreground="#40FFFFFF"
                       FontFamily="Fonts/#TT Norms"
                       FontSize="10"
                       FontWeight="Bold"/>
            <TextBlock Text="v1.0.0 — FiveM Edition"
                       Foreground="#25FFFFFF"
                       FontFamily="Fonts/#TT Norms"
                       FontSize="9"/>
        </StackPanel>
    </Grid>
</UserControl>
