<UserControl x:Class="ToolKitV.Views.Menu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ToolKitV.Views"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Section label -->
        <TextBlock Grid.Row="0"
                   Text="TOOLS"
                   Foreground="#40FFFFFF"
                   FontFamily="Fonts/#TT Norms"
                   FontSize="10"
                   FontWeight="Bold"
                   Margin="16 20 0 12"/>

        <!-- Nav items -->
        <StackPanel Grid.Row="1" Margin="10 0">

            <!-- Texture Optimizer -->
            <Border x:Name="TextureOptimizerItem"
                    Height="46" CornerRadius="8" Margin="0 2"
                    Cursor="Hand"
                    MouseLeftButtonDown="TextureOptimizer_Click">
                <Grid>
                    <!-- Active gradient bg (visible when selected) -->
                    <Border x:Name="TextureOptimizerBg" CornerRadius="8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#30C0132A" Offset="0"/>
                                <GradientStop Color="#15C0132A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Inactive bg (visible when not selected) -->
                    <Border x:Name="TextureOptimizerInactiveBg" CornerRadius="8"
                            Background="#10FFFFFF" Visibility="Collapsed"/>

                    <!-- Left accent stripe (active only) -->
                    <Rectangle x:Name="TextureOptimizerStripe"
                               Width="3" HorizontalAlignment="Left" RadiusX="2" RadiusY="2">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FF5555" Offset="0"/>
                                <GradientStop Color="#C0132A" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14 0 0 0">
                        <TextBlock Text="🖼" FontSize="14" VerticalAlignment="Center" Margin="0 0 10 0"/>
                        <TextBlock x:Name="TextureOptimizerLabel"
                                   Text="Texture Optimizer"
                                   Foreground="#FFFFFFFF"
                                   FontFamily="Fonts/#TT Norms"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Vehicles -->
            <Border x:Name="VehiclesItem"
                    Height="46" CornerRadius="8" Margin="0 2"
                    Cursor="Hand"
                    MouseLeftButtonDown="Vehicles_Click">
                <Grid>
                    <!-- Active gradient bg -->
                    <Border x:Name="VehiclesBg" CornerRadius="8" Visibility="Collapsed">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#30C0132A" Offset="0"/>
                                <GradientStop Color="#15C0132A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Inactive bg -->
                    <Border x:Name="VehiclesInactiveBg" CornerRadius="8" Background="#10FFFFFF"/>

                    <!-- Left accent stripe (hidden when inactive) -->
                    <Rectangle x:Name="VehiclesStripe"
                               Width="3" HorizontalAlignment="Left" RadiusX="2" RadiusY="2"
                               Visibility="Collapsed">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FF5555" Offset="0"/>
                                <GradientStop Color="#C0132A" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="17 0 0 0">
                        <TextBlock Text="🚗" FontSize="14" VerticalAlignment="Center" Margin="0 0 10 0"/>
                        <TextBlock x:Name="VehiclesLabel"
                                   Text="Vehicle Tools"
                                   Foreground="#B0FFFFFF"
                                   FontFamily="Fonts/#TT Norms"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Asset Analyzer -->
            <Border x:Name="AssetAnalyzerItem"
                    Height="46" CornerRadius="8" Margin="0 2"
                    Cursor="Hand"
                    MouseLeftButtonDown="AssetAnalyzer_Click">
                <Grid>
                    <!-- Active gradient bg -->
                    <Border x:Name="AssetAnalyzerBg" CornerRadius="8" Visibility="Collapsed">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#30C0132A" Offset="0"/>
                                <GradientStop Color="#15C0132A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Inactive bg -->
                    <Border x:Name="AssetAnalyzerInactiveBg" CornerRadius="8" Background="#10FFFFFF"/>

                    <!-- Left accent stripe (hidden when inactive) -->
                    <Rectangle x:Name="AssetAnalyzerStripe"
                               Width="3" HorizontalAlignment="Left" RadiusX="2" RadiusY="2"
                               Visibility="Collapsed">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FF5555" Offset="0"/>
                                <GradientStop Color="#C0132A" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="17 0 0 0">
                        <TextBlock Text="📊" FontSize="14" VerticalAlignment="Center" Margin="0 0 10 0"/>
                        <TextBlock x:Name="AssetAnalyzerLabel"
                                   Text="Asset Analyzer"
                                   Foreground="#B0FFFFFF"
                                   FontFamily="Fonts/#TT Norms"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Model Viewer -->
            <Border x:Name="ModelViewerItem"
                    Height="46" CornerRadius="8" Margin="0 2"
                    Cursor="Hand"
                    MouseLeftButtonDown="ModelViewer_Click">
                <Grid>
                    <!-- Active gradient bg -->
                    <Border x:Name="ModelViewerBg" CornerRadius="8" Visibility="Collapsed">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#30C0132A" Offset="0"/>
                                <GradientStop Color="#15C0132A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Inactive bg -->
                    <Border x:Name="ModelViewerInactiveBg" CornerRadius="8" Background="#10FFFFFF"/>

                    <!-- Left accent stripe (hidden when inactive) -->
                    <Rectangle x:Name="ModelViewerStripe"
                               Width="3" HorizontalAlignment="Left" RadiusX="2" RadiusY="2"
                               Visibility="Collapsed">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FF5555" Offset="0"/>
                                <GradientStop Color="#C0132A" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="17 0 0 0">
                        <TextBlock Text="🎲" FontSize="14" VerticalAlignment="Center" Margin="0 0 10 0"/>
                        <TextBlock x:Name="ModelViewerLabel"
                                   Text="3D Model Viewer"
                                   Foreground="#B0FFFFFF"
                                   FontFamily="Fonts/#TT Norms"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Audio Preview -->
            <Border x:Name="AudioViewerItem"
                    Height="46" CornerRadius="8" Margin="0 2"
                    Cursor="Hand"
                    MouseLeftButtonDown="AudioViewer_Click">
                <Grid>
                    <!-- Active gradient bg -->
                    <Border x:Name="AudioViewerActiveBg" CornerRadius="8" Visibility="Collapsed">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#30C0132A" Offset="0"/>
                                <GradientStop Color="#15C0132A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Inactive bg -->
                    <Border x:Name="AudioViewerInactiveBg" CornerRadius="8" Background="#10FFFFFF"/>

                    <!-- Left accent stripe (hidden when inactive) -->
                    <Rectangle x:Name="AudioViewerStripe"
                               Width="3" HorizontalAlignment="Left" RadiusX="2" RadiusY="2"
                               Visibility="Collapsed">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FF5555" Offset="0"/>
                                <GradientStop Color="#C0132A" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="17 0 0 0">
                        <TextBlock Text="🔊" FontSize="14" VerticalAlignment="Center" Margin="0 0 10 0"/>
                        <TextBlock x:Name="AudioViewerLabel"
                                   Text="Audio Preview"
                                   Foreground="#B0FFFFFF"
                                   FontFamily="Fonts/#TT Norms"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Clothing Tools -->
            <Border x:Name="ClothingToolsItem"
                    Height="46" CornerRadius="8" Margin="0 2"
                    Cursor="Hand"
                    MouseLeftButtonDown="ClothingTools_Click">
                <Grid>
                    <!-- Active gradient bg -->
                    <Border x:Name="ClothingToolsBg" CornerRadius="8" Visibility="Collapsed">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#30C0132A" Offset="0"/>
                                <GradientStop Color="#15C0132A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Inactive bg -->
                    <Border x:Name="ClothingToolsInactiveBg" CornerRadius="8" Background="#10FFFFFF"/>

                    <!-- Left accent stripe (hidden when inactive) -->
                    <Rectangle x:Name="ClothingToolsStripe"
                               Width="3" HorizontalAlignment="Left" RadiusX="2" RadiusY="2"
                               Visibility="Collapsed">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FF5555" Offset="0"/>
                                <GradientStop Color="#C0132A" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="17 0 0 0">
                        <TextBlock Text="👕" FontSize="14" VerticalAlignment="Center" Margin="0 0 10 0"/>
                        <TextBlock x:Name="ClothingToolsLabel"
                                   Text="Clothing Tools"
                                   Foreground="#B0FFFFFF"
                                   FontFamily="Fonts/#TT Norms"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Margin="16 0 0 16">
            <TextBlock Text="TGTheAnimator"
                       Foreground="#40FFFFFF"
                       FontFamily="Fonts/#TT Norms"
                       FontSize="10"
                       FontWeight="Bold"/>
            <TextBlock x:Name="VersionText"
                       Text="v3.0.5"
                       Foreground="#25FFFFFF"
                       FontFamily="Fonts/#TT Norms"
                       FontSize="9"/>
            <TextBlock x:Name="UpdateBanner"
                       Text="• UPDATE AVAILABLE"
                       Foreground="#4CFF70"
                       FontFamily="Fonts/#TT Norms"
                       FontSize="12"
                       FontWeight="Bold"
                       Margin="0 2 0 0"
                       Cursor="Hand"
                       Visibility="Collapsed"
                       MouseLeftButtonDown="UpdateBanner_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
