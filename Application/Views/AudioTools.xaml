<UserControl x:Class="ToolKitV.Views.AudioTools"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ToolKitV.Views"
             mc:Ignorable="d">

    <Grid Margin="28 20 28 20" AllowDrop="True" Drop="UIElement_OnDrop">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" LastChildFill="True">
            <Grid DockPanel.Dock="Bottom" Margin="0 16 0 0">
                <local:Button x:Name="OptimizeButton"
                              Title="Optimize Audio (.AWC)"
                              IsButtonEnabledValue="False"
                              Click="OptimizeButton_Click"/>
            </Grid>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0 0 8 0">
                <StackPanel>
                    <TextBlock Text="RESOURCE"
                               Foreground="#40FFFFFF"
                               FontFamily="Fonts/#TT Norms"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0 0 0 10"/>

                    <local:SelectFolder
                        x:Name="ResourceFolder"
                        Title="Resource Folder"
                        PropertyChanged="OnResourcePathChanged"/>

                    <TextBlock Text="AUDIO SETTINGS"
                               Foreground="#40FFFFFF"
                               FontFamily="Fonts/#TT Norms"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0 22 0 10"/>

                    <local:ToogleButton
                        x:Name="DownsampleAudio"
                        Title="Downsample to 24000Hz"
                        Description="Halves the size of massive 48kHz soundbanks to fix 32MB streaming crashes. Minimal loss to engine sounds."
                        IsToogled="True"
                        Margin="0 0 0 10"
                        PropertyChanged="OnSettingsChanged"/>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <StackPanel Grid.Column="2">
            <!-- RESULTS card -->
            <Border CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="#15FFFFFF"
                    Background="#0CFFFFFF"
                    Padding="18 14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                        <Rectangle Width="3" Height="14" RadiusX="2" RadiusY="2" Margin="0 0 8 0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF5555" Offset="0"/>
                                    <GradientStop Color="#C0132A" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <TextBlock Text="OPTIMIZATION RESULTS"
                                   Foreground="#80FFFFFF"
                                   FontFamily="Fonts/#TT Norms"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="AWC Files Processed" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ResultFiles" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Total Size Reduced" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ResultSize" Grid.Column="1" Text="—" Foreground="#4CFF70" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Status" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ResultStatus" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
