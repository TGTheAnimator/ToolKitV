<Window x:Class="ToolKitV.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TGToolKit" Height="450" Width="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">
    <Border CornerRadius="12" ClipToBounds="True" Background="#0D0D0F" BorderBrush="#30FFFFFF" BorderThickness="1">
        <Grid>
            <Image Source="../Assets/Images/bg.bmp" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
            
            <!-- Subtle gradient overlay -->
            <Border>
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.5" RadiusX="0.7" RadiusY="0.7">
                        <GradientStop Color="#00000000" Offset="0.5"/>
                        <GradientStop Color="#800D0D0F" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <!-- Bottom branding -->
            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="20">
                <TextBlock Text="TGTOOLKIT" Foreground="White" FontSize="18" FontWeight="Bold">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="Black"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="INITIALIZING..." Foreground="#80FFFFFF" FontSize="10" HorizontalAlignment="Right" Margin="0 2 0 0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
