<UserControl x:Class="ToolKitV.Views.Stats"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ToolKitV.Views"
             mc:Ignorable="d">
    <DockPanel LastChildFill="False">

        <!-- ─── SCAN DATA card ─── -->
        <Border DockPanel.Dock="Top"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="#15FFFFFF"
                Background="#0CFFFFFF"
                Padding="18 14"
                Margin="0 0 0 16">
            <StackPanel>
                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                    <Rectangle Width="3" Height="14" RadiusX="2" RadiusY="2" Margin="0 0 8 0">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FF5555" Offset="0"/>
                                <GradientStop Color="#C0132A" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <TextBlock Text="SCAN DATA"
                               Foreground="#80FFFFFF"
                               FontFamily="Fonts/#TT Norms"
                               FontSize="10"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Stats rows -->
                <Grid Margin="0 0 0 6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Files found"
                               Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                    <TextBlock x:Name="FilesCount" Grid.Column="1"
                               Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"
                               Text="—"/>
                </Grid>

                <Grid Margin="0 0 0 6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Oversized  (>16 MB virtual)"
                               Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                    <TextBlock x:Name="OversizedCount" Grid.Column="1"
                               Foreground="#FF5555" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"
                               Text="—"/>
                </Grid>

                <Grid Margin="0 0 0 6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Virtual size  (GPU)"
                               Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                    <TextBlock x:Name="VirtualSize" Grid.Column="1"
                               Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"
                               Text="—"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Physical size  (disk)"
                               Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                    <TextBlock x:Name="PhysicalSize" Grid.Column="1"
                               Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"
                               Text="—"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ─── RESULTS card ─── -->
        <Border DockPanel.Dock="Top"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="#15FFFFFF"
                Background="#0CFFFFFF"
                Padding="18 14">
            <StackPanel>
                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                    <Rectangle Width="3" Height="14" RadiusX="2" RadiusY="2" Margin="0 0 8 0">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FF5555" Offset="0"/>
                                <GradientStop Color="#C0132A" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <TextBlock Text="RESULTS"
                               Foreground="#80FFFFFF"
                               FontFamily="Fonts/#TT Norms"
                               FontSize="10"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Grid Margin="0 0 0 6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="New physical size"
                               Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                    <TextBlock x:Name="FilesSizeResult" Grid.Column="1"
                               Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"
                               Text="—"/>
                </Grid>

                <Grid Margin="0 0 0 6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Textures optimized"
                               Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                    <TextBlock x:Name="OptimizedFiles" Grid.Column="1"
                               Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"
                               Text="—"/>
                </Grid>

                <Grid Margin="0 0 0 6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Space saved"
                               Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                    <TextBlock x:Name="OptimizedSize" Grid.Column="1"
                               Foreground="#4CFF70" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"
                               Text="—"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Reduction"
                               Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                    <TextBlock x:Name="OptimizedProcent" Grid.Column="1"
                               Foreground="#4CFF70" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"
                               Text="—"/>
                </Grid>
            </StackPanel>
        </Border>

    </DockPanel>
</UserControl>
