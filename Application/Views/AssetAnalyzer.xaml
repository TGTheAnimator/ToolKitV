<UserControl x:Class="ToolKitV.Views.AssetAnalyzer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ToolKitV.Views"
             mc:Ignorable="d">

    <Grid Margin="28 20 28 20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ COLUMN 0 — Settings + Action Buttons ══ -->
        <DockPanel Grid.Column="0" LastChildFill="True">
            
            <Grid DockPanel.Dock="Bottom" Margin="0 16 0 0">
                <local:Button x:Name="RunAuditButton"
                              Title="Run Asset Audit"
                              IsButtonEnabledValue="False"
                              Click="RunAuditButton_Click"/>
            </Grid>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0 0 8 0">
                <StackPanel>
                    <TextBlock Text="TARGET RESOURCE"
                               Foreground="#40FFFFFF"
                               FontFamily="Fonts/#TT Norms"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0 0 0 10"/>

                    <local:SelectFolder
                        x:Name="ResourceFolder"
                        Title="Resource Folder"
                        PropertyChanged="OnResourcePathChanged"/>

                    <TextBlock Text="ABOUT ASSET AUDIT"
                               Foreground="#40FFFFFF"
                               FontFamily="Fonts/#TT Norms"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0 22 0 10"/>

                    <Border CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="#15FFFFFF"
                            Background="#0CFFFFFF"
                            Padding="14 12">
                        <StackPanel>
                            <TextBlock Text="Analyzes a resource folder to accurately calculate the real streaming memory budget used by FiveM."
                                       Foreground="#70FFFFFF"
                                       FontFamily="Fonts/#TT Norms"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0 0 0 8"/>
                            <TextBlock Text="It checks YTD, YFT, YDR, YDD, YBN for their RSC7 virtual size, and AWC for its loaded disk size."
                                       Foreground="#70FFFFFF"
                                       FontFamily="Fonts/#TT Norms"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- ══ COLUMN 2 — Results Panel ══ -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0 0 8 0">
            <StackPanel>
                
                <!-- SUMMARY RESULTS card -->
                <Border CornerRadius="10"
                        BorderThickness="1"
                        BorderBrush="#15FFFFFF"
                        Background="#0CFFFFFF"
                        Padding="18 14"
                        Margin="0 0 0 16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                            <Rectangle Width="3" Height="14" RadiusX="2" RadiusY="2" Margin="0 0 8 0">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#00B0FF" Offset="0"/>
                                        <GradientStop Color="#0065FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <TextBlock Text="BUDGET SUMMARY"
                                       Foreground="#80FFFFFF"
                                       FontFamily="Fonts/#TT Norms"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid Margin="0 0 0 5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Overall Status" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                            <TextBlock x:Name="ResultStatus" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0 0 0 5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Total Memory Est." Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                            <TextBlock x:Name="ResultTotalMB" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0 0 0 5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Textures (Virtual)" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                            <TextBlock x:Name="ResultTextureMB" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0 0 0 5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Models (Virtual)" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                            <TextBlock x:Name="ResultModelMB" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0 0 0 5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Collision (Virtual)" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                            <TextBlock x:Name="ResultCollisionMB" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Audio (Disk)" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                            <TextBlock x:Name="ResultAudioMB" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- RECOMMENDATIONS card -->
                <Border CornerRadius="10"
                        BorderThickness="1"
                        BorderBrush="#15FFFFFF"
                        Background="#0CFFFFFF"
                        Padding="18 14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                            <Rectangle Width="3" Height="14" RadiusX="2" RadiusY="2" Margin="0 0 8 0">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#00B0FF" Offset="0"/>
                                        <GradientStop Color="#0065FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <TextBlock Text="RECOMMENDATIONS"
                                       Foreground="#80FFFFFF"
                                       FontFamily="Fonts/#TT Norms"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl x:Name="RecommendationsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0 4 0 4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="14"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="•" Foreground="#C0132A" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="{Binding}" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" TextWrapping="Wrap"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <TextBlock x:Name="NoRecommendationsText" Text="Resource is clean and safe." Foreground="#4CFF70" FontFamily="Fonts/#TT Norms" FontSize="12" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
