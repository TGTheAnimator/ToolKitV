<UserControl x:Class="ToolKitV.Views.TextureOptimization"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ToolKitV.Views"
             mc:Ignorable="d">
    <Grid>
        <StackPanel Orientation="Horizontal">
            <StackPanel Margin="0 -5 0 0">
                <local:SelectFolder
                    x:Name="MainFolder"
                    Title="Textures Folder"
                    PropertyChanged="OnMainPathChanged"/>

                <StackPanel Margin="0 10 0 0">
                    <!--<local:ToogleButton
                        Title ="Backup"/>-->

                    <local:SelectFolder
                        x:Name="BackupFolder"
                        Title="Backup Folder"
                        PropertyChanged="OnBackupPathChanged"/>
                </StackPanel>

                <StackPanel Margin="0 10 0 0">
                    <local:ToogleButton
                        x:Name="OnlyOverSized"
                        Title="Only oversized texture dictionaries"
                        Description="Only process YTDs whose virtual (GPU) size exceeds 16 MB&#10;— the FiveM streaming budget threshold."
                        PropertyChanged="OnOnlyOverSizedTexturesChanged"/>
                </StackPanel>

                <StackPanel Margin="0 0 0 0">
                    <local:InputNumber
                        x:Name="OptimizeSize"
                        Title="Optimize Size (Width + Height px)"
                        Description="Textures whose Width+Height meets this threshold are reprocessed.&#10;Recommended for FiveM: 4096 (2048×2048). Lower = more textures optimized."
                        NumberValue="4096"
                        PropertyChanged="OptimizeSize_PropertyChanged"/>
                </StackPanel>

                <StackPanel Margin="0 10 0 0">
                    <local:ToogleButton
                        x:Name="Downsize"
                        Title="Downsize (÷2)"
                        Description="Halves texture dimensions. Recommended for props/vehicles.&#10;Avoid on UI/script textures (handled automatically)."
                        PropertyChanged="Downsize_PropertyChanged"
                        IsToogled="True"/>
                </StackPanel>

                <StackPanel Margin="0 10 0 0">
                    <local:ToogleButton
                        x:Name="FormatOptimize"
                        Title="Format Optimization (BC7/BC1/BC4)"
                        Description="Re-encodes textures to the best compressed format for their channel count.&#10;BC7 for RGBA, BC1 for RGB, BC4 for grayscale. Minimal quality loss."
                        PropertyChanged="FormatOptimize_PropertyChanged"/>
                </StackPanel>

                <StackPanel Margin="0 35 0 0" Orientation="Horizontal">
                    <local:Button x:Name="OptimizeButton" Title="Optimize" IsButtonEnabledValue="False" Click="OptimizeButton_Click"/>
                    <local:Button x:Name="AnalyzeButton" Title="Analyze" IsButtonEnabledValue="False" Click="AnalyzeButton_Click" Margin="30 0 0 0"/>
                </StackPanel>
            </StackPanel>

            <local:Stats Margin="190 0 0 0" x:Name="Stats"/>
        </StackPanel>
    </Grid>
</UserControl>
