<UserControl x:Class="ToolKitV.Views.VehicleTools"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ToolKitV.Views"
             mc:Ignorable="d">

    <Grid Margin="28 20 28 20" AllowDrop="True" Drop="UIElement_OnDrop">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ COLUMN 0 — Settings + Action Buttons ══ -->
        <DockPanel Grid.Column="0" LastChildFill="True">

            <!-- Buttons pinned to bottom -->
            <Grid DockPanel.Dock="Bottom" Margin="0 16 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <local:Button x:Name="ScanModelsButton"
                              Grid.Column="0"
                              Title="Scan YFT Models"
                              IsButtonEnabledValue="False"
                              Click="ScanModelsButton_Click"/>

                <local:Button x:Name="MergeButton"
                              Grid.Column="2"
                              Title="Merge Meta"
                              IsButtonEnabledValue="False"
                              Click="MergeButton_Click"/>
            </Grid>

            <Grid DockPanel.Dock="Bottom" Margin="0 16 0 0">
                <local:Button x:Name="ScanButton"
                              Title="Scan Meta Files"
                              IsButtonEnabledValue="False"
                              Click="ScanButton_Click"/>
            </Grid>

            <!-- Scrollable settings -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0 0 8 0">
                <StackPanel>

                    <!-- ─── Section: Resource ─── -->
                    <TextBlock Text="RESOURCE"
                               Foreground="#40FFFFFF"
                               FontFamily="Fonts/#TT Norms"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0 0 0 10"/>

                    <local:SelectFolder
                        x:Name="ResourceFolder"
                        Title="Vehicle Pack Folder"
                        PropertyChanged="OnResourcePathChanged"/>

                    <local:SelectFolder
                        x:Name="BackupFolder"
                        Title="Backup Folder (strongly recommended)"
                        Margin="0 12 0 0"
                        PropertyChanged="OnBackupPathChanged"/>

                    <!-- ─── Section: Options ─── -->
                    <TextBlock Text="OPTIONS"
                               Foreground="#40FFFFFF"
                               FontFamily="Fonts/#TT Norms"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0 22 0 10"/>

                    <local:ToogleButton
                        x:Name="CleanupSources"
                        Title="Remove source files after merge"
                        Description="Deletes original per-vehicle .meta files once merged masters are written. Empty folders are pruned. Backups are kept."
                        IsToogled="False"
                        PropertyChanged="CleanupSources_PropertyChanged"/>

                    <!-- ─── Section: What Gets Merged ─── -->
                    <TextBlock Text="WHAT GETS MERGED"
                               Foreground="#40FFFFFF"
                               FontFamily="Fonts/#TT Norms"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0 22 0 10"/>

                    <!-- Info card -->
                    <Border CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="#15FFFFFF"
                            Background="#0CFFFFFF"
                            Padding="14 12">
                        <StackPanel>
                            <TextBlock Text="All meta files found recursively will be merged:"
                                       Foreground="#70FFFFFF"
                                       FontFamily="Fonts/#TT Norms"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0 0 0 8"/>
                            <Grid Margin="0 2">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="•" Foreground="#C0132A" FontFamily="Fonts/#TT Norms" FontSize="11"/>
                                <TextBlock Grid.Column="1" Foreground="#C0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="11"
                                           Text="vehicles.meta — InitDatas + txdRelationships"/>
                            </Grid>
                            <Grid Margin="0 2">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="•" Foreground="#C0132A" FontFamily="Fonts/#TT Norms" FontSize="11"/>
                                <TextBlock Grid.Column="1" Foreground="#C0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="11"
                                           Text="handling.meta — HandlingData (deduped by handlingName)"/>
                            </Grid>
                            <Grid Margin="0 2">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="•" Foreground="#C0132A" FontFamily="Fonts/#TT Norms" FontSize="11"/>
                                <TextBlock Grid.Column="1" Foreground="#C0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="11"
                                           Text="carcols.meta — Kits (modkit ID conflicts auto-remapped) + Lights + Sirens"/>
                            </Grid>
                            <Grid Margin="0 2">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="•" Foreground="#C0132A" FontFamily="Fonts/#TT Norms" FontSize="11"/>
                                <TextBlock Grid.Column="1" Foreground="#C0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="11"
                                           Text="carvariations.meta — kit ID references corrected automatically"/>
                            </Grid>
                            <Grid Margin="0 2">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="•" Foreground="#C0132A" FontFamily="Fonts/#TT Norms" FontSize="11"/>
                                <TextBlock Grid.Column="1" Foreground="#C0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="11"
                                           Text="vehiclelayouts.meta — layouts (deduped by layoutName)"/>
                            </Grid>
                            <TextBlock Text="Output → [resource]/data/   +   fxmanifest_snippet.lua"
                                       Foreground="#50FFFFFF"
                                       FontFamily="Fonts/#TT Norms"
                                       FontSize="10"
                                       TextWrapping="Wrap"
                                       Margin="0 10 0 0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- ══ COLUMN 2 — Results Panel ══ -->
        <StackPanel Grid.Column="2">

            <!-- SCAN RESULTS card -->
            <Border CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="#15FFFFFF"
                    Background="#0CFFFFFF"
                    Padding="18 14"
                    Margin="0 0 0 16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                        <Rectangle Width="3" Height="14" RadiusX="2" RadiusY="2" Margin="0 0 8 0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF5555" Offset="0"/>
                                    <GradientStop Color="#C0132A" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <TextBlock Text="SCAN RESULTS"
                                   Foreground="#80FFFFFF"
                                   FontFamily="Fonts/#TT Norms"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="vehicles.meta found" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ScanVehiclesCount" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="handling.meta found" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ScanHandlingCount" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="carcols.meta found" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ScanCarcolsCount" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="carvariations.meta found" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ScanVariationsCount" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="vehiclelayouts.meta found" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ScanLayoutsCount" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- MERGE RESULTS card -->
            <Border CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="#15FFFFFF"
                    Background="#0CFFFFFF"
                    Padding="18 14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                        <Rectangle Width="3" Height="14" RadiusX="2" RadiusY="2" Margin="0 0 8 0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF5555" Offset="0"/>
                                    <GradientStop Color="#C0132A" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <TextBlock Text="MERGE RESULTS"
                                   Foreground="#80FFFFFF"
                                   FontFamily="Fonts/#TT Norms"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Vehicles merged" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ResultVehicles" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Handling entries merged" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ResultHandling" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Kits / Lights / Sirens merged" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ResultKitsLights" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Variations merged" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ResultVariations" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Kit + Siren ID conflicts resolved" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ResultConflicts" Grid.Column="1" Text="—" Foreground="#FF5555" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Duplicates skipped" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ResultDupes" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Status" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ResultStatus" Grid.Column="1" Text="—" Foreground="#4CFF70" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- YFT SCAN RESULTS card -->
            <Border CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="#15FFFFFF"
                    Background="#0CFFFFFF"
                    Padding="18 14"
                    Margin="0 16 0 0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                        <Rectangle Width="3" Height="14" RadiusX="2" RadiusY="2" Margin="0 0 8 0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF5555" Offset="0"/>
                                    <GradientStop Color="#C0132A" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <TextBlock Text="YFT MODEL SCAN"
                                   Foreground="#80FFFFFF"
                                   FontFamily="Fonts/#TT Norms"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Models Scanned" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ModelScanTotal" Grid.Column="1" Text="—" Foreground="#E0FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Safe Models" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ModelScanSafe" Grid.Column="1" Text="—" Foreground="#4CFF70" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Warnings (> 50k verts)" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ModelScanWarnings" Grid.Column="1" Text="—" Foreground="#FFA500" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Critical (> 64k verts / 16MB)" Foreground="#55FFFFFF" FontFamily="Fonts/#TT Norms" FontSize="12"/>
                        <TextBlock x:Name="ModelScanCritical" Grid.Column="1" Text="—" Foreground="#FF5555" FontFamily="Fonts/#TT Norms" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</UserControl>
