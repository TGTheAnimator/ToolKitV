<Application x:Class="ToolKitV.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ToolKitV">
    <Application.Resources>
        <FontFamily x:Key="TT Norms Regular">Assets/Fonts/#TT Norms Regular</FontFamily>
        <FontFamily x:Key="TT Norms Medium">Assets/Fonts/#TT Norms Medium</FontFamily>
        <FontFamily x:Key="TT Norms Bold">Assets/Fonts/#TT Norms Bold</FontFamily>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource TT Norms Bold}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
